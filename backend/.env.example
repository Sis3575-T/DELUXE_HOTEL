## Example for MongoDB Atlas (replace placeholders):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/Abay_Grand_Hotel?retryWrites=true&w=majority

## Example for local MongoDB (recommended for Compass/local dev):
MONGODB_URI=mongodb://127.0.0.1:27017/Abay_Grand_Hotel
MONGODB_DB_NAME=Abay_Grand_Hotel

# Cloudinary (replace with your credentials)
CLOUDINARY_NAME=<your_cloudinary_name>
CLOUDINARY_API_KEY=<your_cloudinary_api_key>
CLOUDINARY_SECRET_KEY=<your_cloudinary_secret_key>

# Admin user for initial setup
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=changeMe
ADMIN_NAME=Administrator
ADMIN_ROLE=Admin

# JWT secret for signing tokens
JWT_SECRET=change_this_secret

# Optional: Atlas Data API fallback
# DATA_API_URL=https://data.mongodb-api.com/app/<app-id>/endpoint/data/v1
# DATA_API_KEY=<your_data_api_key>

# Copy this file to .env and fill in real values before running the server